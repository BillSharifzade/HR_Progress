# Copy to deploy/.env and edit. Required: JWT_SECRET.
APP_ENV=development
HTTP_PORT=8080

POSTGRES_USER=hrprogress
POSTGRES_PASSWORD=hrprogress
POSTGRES_DB=hrprogress

# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_64_HEX_CHARS

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

LOG_LEVEL=info
DEFAULT_TIMEZONE=Europe/Moscow

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin

# In dev keep "*"; in production set the public origin (e.g. https://hr.example.com).
CORS_ALLOWED_ORIGINS=*

# 1F (Первая форма) sync. Leave ONEF_BASE_URL empty to disable.
ONEF_BASE_URL=
ONEF_AUTH_TOKEN=
ONEF_SYNC_INTERVAL=24h
